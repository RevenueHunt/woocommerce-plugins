{
  "name": "revenuehunt/woocommerce-plugins",
  "description": "Single source of truth for RevenueHunt's WordPress & WooCommerce plugins (Product Recommendation Quiz). One source builds two distribution artifacts.",
  "type": "project",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5 || ^10.5",
    "brain/monkey": "^2.6",
    "squizlabs/php_codesniffer": "^3.11",
    "wp-coding-standards/wpcs": "^3.1",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpstan/phpstan": "^1.12",
    "szepeviktor/phpstan-wordpress": "^1.3",
    "phpstan/extension-installer": "^1.4",
    "digitalrevolution/php-codesniffer-baseline": "^1.3"
  },
  "autoload-dev": {
    "psr-4": {
      "RevenueHunt\\PRQ\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "build": "php tools/build.php all",
    "i18n:pot": "bash tools/make-pot.sh",
    "lint": "phpcs",
    "lint:fix": "phpcbf",
    "analyse": "phpstan analyse --memory-limit=1G",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "platform-check": false,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true,
      "digitalrevolution/php-codesniffer-baseline": true
    }
  }
}
