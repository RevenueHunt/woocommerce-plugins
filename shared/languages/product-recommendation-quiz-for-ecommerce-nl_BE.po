#, php-format
msgid "Are you having trouble granting access? Check out %s"
msgstr "Heb je moeite met toegang geven? Afrekenen %s"

#: admin/class-product-recommendation-quiz-for-ecommerce-admin-page.php:168
msgid "You do not have sufficient permissions to access this page."
msgstr "Je hebt niet voldoende rechten om deze pagina te bezoeken."

#: admin/class-product-recommendation-quiz-for-ecommerce-admin-page.php:169
msgid "Permission Denied"
msgstr "Toestemming geweigerd"

#: admin/class-product-recommendation-quiz-for-ecommerce-admin-page.php:220
msgid "The cURL extension is required but not installed on your server."
msgstr "De cURL extensie is vereist maar niet geïnstalleerd op je server."

#: rest/class-product-recommendation-quiz-for-ecommerce-rest-set-token-controller.php:176
msgid "Too many requests. Please try again later."
msgstr "Te veel verzoeken. Probeer het later opnieuw."

#: rest/class-product-recommendation-quiz-for-ecommerce-rest-set-token-controller.php:210
msgid "Invalid shop hashid format. Only alphanumeric characters are allowed."
msgstr "Ongeldig winkel hashid formaat. Alleen alfanumerieke karakters zijn toegestaan."

#: rest/class-product-recommendation-quiz-for-ecommerce-rest-set-token-controller.php:219
msgid "Invalid api_key format."
msgstr "Ongeldig api_key-formaat."

